{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist"
  },
  "include": [
    "playwright/**/*.ts",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "cypress"
  ]
}
