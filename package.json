{
  "name": "qa-engineer",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npx cypress run",
    "test:smoke": "npx cypress run --spec 'cypress/e2e/REQ-001-carga-portal.cy.js'",
    "test:all-specs": "npx cypress run --spec 'cypress/e2e/REQ-001-carga-portal.cy.js,cypress/e2e/REQ-002-login-visibilidad.cy.js'",
    "test:uat": "npx cypress run --env environment=uat",
    "test:prod": "npx cypress run --env environment=prod",
    "cy:open": "npx cypress open",
    "email:start": "node email-server.js",
    "lint": "echo 'lint ok'",
    "test:allure": "npx cypress run --env allure=true",
    "allure:report": "npx allure generate allure-results --clean -o allure-report",
    "allure:open": "npx allure open allure-report",
    "allure:run": "npm run test:allure && npm run allure:report && npm run allure:open",
    "pw:run": "npx playwright test",
    "pw:smoke": "npx playwright test playwright/e2e/REQ-001-carga-portal.spec.ts",
    "pw:open": "npx playwright test --ui"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.49.0",
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "allure-commandline": "^2.41.0",
    "axe-core": "^4.11.4",
    "cypress": "^15.15.0",
    "cypress-axe": "^1.7.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "nodemailer": "^8.0.7",
    "pptxgenjs": "^4.0.1"
  }
}
